# Google Sheets (Service Account JSON path inside container or raw — см. backend config)
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/service-account.json
# ID таблицы из URL: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SPREADSHEET_ID=

# Имена вкладок в таблице (как в Google Sheets, с учётом регистра)
SHEET_NAME_SUBS=sub-bass
SHEET_NAME_ENQUIRIES=Enquiries
SHEET_NAME_DOMASHKI=Domashki
SHEET_NAME_ANKETY=Анкеты
SHEET_NAME_INTERVIEWS=Собес
# Первая колонка с данными кандидата на листе «Собеседования» (0 = A, 3 = D)
SHEET_INTERVIEWS_FIRST_CANDIDATE_COL_INDEX=3

# Запись в Google Sheets через очередь RQ (воркер docker-compose service worker)
# Пауза после каждого успешного write (сек); повторы при 429/503
GOOGLE_SHEETS_WRITE_INTERVAL_SEC=0.6
GOOGLE_SHEETS_WRITE_MAX_RETRIES=6

# БД приложения (пользователи, назначения). В Docker по умолчанию SQLite в /app/data
# DATABASE_URL=sqlite:////app/data/koord.db

# JWT / приложение
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Первый супер-админ (сид при старте, опционально)
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me

# Мастера отбора: при старте создаются MASTER_COUNT учёток master01@…@MASTER_SEED_DOMAIN (роль user).
# MASTER_COUNT=0 — не создавать автоматически.
MASTER_COUNT=20
MASTER_SEED_DOMAIN=koord.local
MASTER_SEED_PASSWORD=changeme
